generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logo             String?
  googleReviewUrl  String
  createdAt        DateTime @default(now())

  qrCode           QRCode?
  reviews          Review[]
  feedbacks        Feedback[]
}

model QRCode {
  id          String   @id @default(cuid())
  businessId  String   @unique
  qrImageUrl  String
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  businessId  String
  rating      Int
  isPositive  Boolean
  scannedAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])
}

model Feedback {
  id          String   @id @default(cuid())
  businessId  String
  rating      Int
  name        String?
  phone       String?
  message     String
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])
}